{
"chip": "esp32e",
"name": "ESP32-E",
"version": "1.0.3",
"description": "Espressif ESP32-E Chipset Package",
"vendor": "Espressif",
"architecture": "xtensa-lx6",

"toolchain_internal": {
"compiler": "xtensa-esp-elf-g++",
"compiler_version": "13.2.0",
"uploader": "esptool",
"uploader_version": "4.x"
},

"toolchain": {
"windows": {
"url": "https://github.com/blesson0077/cube-packages/releases/download/esp32e-1.0.3/esp32e-1.0.3-win.zip",
"sha256": "c4a8a82f4d264403cfb1250deb87c9a85f13061a37ca4e9e6e9fa92c801a9df9",
"bin": "toolchain/xtensa-esp-elf/bin/xtensa-esp-elf-g++.exe"
},
"linux": { "url": "", "sha256": "", "bin": "" },
"mac": { "url": "", "sha256": "", "bin": "" }
},

"includes": {
"core": [
"framework/cores/esp32",
"framework/variants/esp32",
"framework/sdk/esp32/include"
],
"wifi": [
"libraries/WiFi/src",
"libraries/NetworkClientSecure/src"
],
"bluetooth": [
"libraries/BluetoothSerial/src",
"libraries/BLE/src"
]
},

"linker": {
