"-Lframework/sdk/esp32/lib",
"-lapp_trace",
"-lapp_update",
"-lbootloader_support",
"-lesp_wifi",
"-lbt",
"-lnvs_flash",
"-lm",
"-lgcc",
"-lstdc++"
]
},

"upload": {
"tool": "esptool",
"protocol": "uart",
"speed": 921600,
"flags": [
"--chip",
"esp32",
"--before",
"default_reset"
]
},

"dependencies": {
"python": null
}
}
